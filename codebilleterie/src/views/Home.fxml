<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.HomeController"
            stylesheets="@../styles/app.css">

    <children>

        <!-- Le conteneur principal centré -->
        <VBox alignment="CENTER" spacing="20" layoutX="150" layoutY="80"
              styleClass="card">

            <!-- Titre -->
            <Label text="Bienvenue dans la Billetterie"
                   styleClass="title" />

            <!-- Sous-titre -->
            <Label text="Choisissez ce que vous souhaitez faire"
                   styleClass="subtitle"/>

            <!-- Bouton : Voir les événements -->
            <Button text="🎟️ Voir les événements"
                    styleClass="btn-primary"
                    onAction="#goToEvents"/>

            <!-- Bouton : Se connecter -->
            <Button text="🔑 Se connecter"
                    styleClass="btn-secondary"
                    onAction="#goToLogin"/>

            <!-- Bouton : Créer un compte -->
            <Button text="📝 Créer un compte"
                    styleClass="btn-secondary"
                    onAction="#goToRegister"/>

            <Button text="🎟️ Voir les événements"
                    styleClass="btn-primary"
                    onAction="#goToEvents"/>

        

        </VBox>

    </children>
</AnchorPane>