<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.AdminController">

    <top>
        <HBox spacing="10">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>

            <Label text="Dashboard Admin"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Déconnexion" onAction="#logout"/>
        </HBox>
    </top>

    <center>
        <VBox fx:id="adminContainer" spacing="10">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <!-- FORMULAIRE -->
            <Label text="Ajouter un événement"
                   style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

            <TextField fx:id="txtTitle" promptText="Titre" />
            <TextField fx:id="txtCategory" promptText="Catégorie" />
            <TextField fx:id="txtDate" promptText="Date (YYYY-MM-DD)" />
            <TextField fx:id="txtLocation" promptText="Lieu" />
            <TextField fx:id="txtPrice" promptText="Prix" />

            <!-- 🔥 AJOUT IMPORTANT -->
            <TextField fx:id="txtImage" promptText="URL de l'image" />

            <Button text="Ajouter" onAction="#addEvent"/>

            <!-- Message -->
            <Label fx:id="lblMessage"/>

        </VBox>
    </center>

</BorderPane>