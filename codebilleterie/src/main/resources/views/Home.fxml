<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane fx:id="root"
            xmlns="http://javafx.com/javafx/8.0.171"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.HomeController">

    <children>

        <VBox alignment="CENTER"
              spacing="20"
              AnchorPane.topAnchor="0.0"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0"
              styleClass="card">

            <padding>
                <Insets top="40" bottom="40" left="40" right="40"/>
            </padding>

            <Label fx:id="lblUser"
                   styleClass="subtitle"/>

            <Label text="Bienvenue dans la Billetterie"
                   styleClass="title"/>

            <Button fx:id="btnEvents"
                    text="🎟️ Voir les événements"
                    styleClass="btn-primary"
                    onAction="#goToEvents"/>

            <Button fx:id="btnLogin"
                    text="🔑 Se connecter"
                    styleClass="btn-secondary"
                    onAction="#goToLogin"/>

            <Button fx:id="btnRegister"
                    text="📝 Créer un compte"
                    styleClass="btn-secondary"
                    onAction="#goToRegister"/>

            <Button fx:id="btnAdmin"
                    text="📊 Dashboard Admin"
                    onAction="#goToAdmin"/>

            <Button text="🚪 Déconnexion"
                    onAction="#logout"/>

        </VBox>

    </children>
</AnchorPane>