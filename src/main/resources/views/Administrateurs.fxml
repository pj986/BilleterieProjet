<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.AdministrateursController"
            prefWidth="1200"
            prefHeight="750"
            styleClass="page">

    <top>
        <VBox spacing="16" styleClass="events-header">
            <padding>
                <Insets top="25" right="30" bottom="25" left="30"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="18">
                <Button text="← Retour"
                        onAction="#goBack"
                        styleClass="back-button"/>

                <VBox spacing="5">
                    <Label text="Gestion des administrateurs"
                           styleClass="page-title"/>

                    <Label text="Gérez les comptes autorisés à accéder au back-office Tic’n Go."
                           styleClass="page-subtitle"/>
                </VBox>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="12">
                <TextField fx:id="searchField"
                           promptText="Rechercher par nom ou email..."
                           prefWidth="420"
                           onKeyReleased="#handleSearch"
                           styleClass="search-field"/>

                <Button text="Réinitialiser"
                        onAction="#resetSearch"
                        styleClass="secondary-action-button"/>

                <Pane HBox.hgrow="ALWAYS"/>

                <Button text="+ Ajouter un administrateur"
                        onAction="#openAddForm"
                        styleClass="primary-action-button"/>
            </HBox>

            <Label fx:id="lblCount"
                   text="0 administrateur(s)"
                   styleClass="stat-info"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="18" styleClass="dashboard-content">
            <padding>
                <Insets top="25" right="30" bottom="30" left="30"/>
            </padding>

            <TableView fx:id="adminsTable"
                       VBox.vgrow="ALWAYS"
                       columnResizePolicy="CONSTRAINED_RESIZE_POLICY"
                       styleClass="clients-table">

                <columns>
                    <TableColumn fx:id="idColumn"
                                 text="ID"
                                 prefWidth="100"/>

                    <TableColumn fx:id="nomColumn"
                                 text="Nom"
                                 prefWidth="300"/>

                    <TableColumn fx:id="emailColumn"
                                 text="Email"
                                 prefWidth="450"/>
                </columns>

                <placeholder>
                    <Label text="Aucun administrateur trouvé."
                           styleClass="page-subtitle"/>
                </placeholder>
            </TableView>

            <HBox alignment="CENTER_RIGHT" spacing="12">
                <Button text="Actualiser"
                        onAction="#refreshAdministrateurs"
                        styleClass="secondary-action-button"/>

                <Button text="Modifier"
                        onAction="#handleEdit"
                        styleClass="primary-action-button"/>

                <Button text="Changer le mot de passe"
                        onAction="#handlePasswordChange"
                        styleClass="secondary-action-button"/>

                <Button text="Supprimer"
                        onAction="#handleDelete"
                        styleClass="logout-button"/>
            </HBox>

            <Label fx:id="messageLabel"
                   text=""
                   wrapText="true"/>
        </VBox>
    </center>

</BorderPane>