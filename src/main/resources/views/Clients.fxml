<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.ClientsController"
            prefWidth="1200"
            prefHeight="750"
            styleClass="page">

    <!-- EN-TÊTE -->
    <top>
        <VBox spacing="16" styleClass="events-header">

            <padding>
                <Insets top="25"
                        right="30"
                        bottom="25"
                        left="30"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="18">

                <Button text="← Retour"
                        onAction="#goBack"
                        styleClass="back-button"/>

                <VBox spacing="5">

                    <Label text="Gestion des clients"
                           styleClass="page-title"/>

                    <Label text="Consultez, recherchez et gérez les clients de la billetterie Tic’n Go."
                           styleClass="page-subtitle"/>

                </VBox>

            </HBox>

            <!-- BARRE DE RECHERCHE -->
            <HBox alignment="CENTER_LEFT" spacing="12">

                <TextField fx:id="searchField"
                           promptText="Rechercher par nom, email ou téléphone..."
                           prefWidth="420"
                           onKeyReleased="#handleSearch"
                           styleClass="search-field"/>

                <Button text="Réinitialiser"
                        onAction="#resetSearch"
                        styleClass="secondary-action-button"/>

                <Pane HBox.hgrow="ALWAYS"/>

                <Button text="+ Ajouter un client"
                        onAction="#openAddForm"
                        styleClass="primary-action-button"/>

            </HBox>

            <!-- COMPTEUR -->
            <Label fx:id="lblCount"
                   text="0 client(s)"
                   styleClass="stat-info"/>

        </VBox>
    </top>

    <!-- CONTENU PRINCIPAL -->
    <center>
        <VBox spacing="18" styleClass="dashboard-content">

            <padding>
                <Insets top="25"
                        right="30"
                        bottom="30"
                        left="30"/>
            </padding>

            <!-- TABLEAU -->
            <TableView fx:id="clientsTable"
                       VBox.vgrow="ALWAYS"
                       columnResizePolicy="CONSTRAINED_RESIZE_POLICY"
                       styleClass="clients-table">

                <columns>

                    <TableColumn fx:id="idColumn"
                                 text="ID"
                                 prefWidth="70"/>

                    <TableColumn fx:id="nomColumn"
                                 text="Nom"
                                 prefWidth="170"/>

                    <TableColumn fx:id="emailColumn"
                                 text="Email"
                                 prefWidth="230"/>

                    <TableColumn fx:id="telephoneColumn"
                                 text="Téléphone"
                                 prefWidth="140"/>

                    <TableColumn fx:id="adresseColumn"
                                 text="Adresse"
                                 prefWidth="260"/>

                    <TableColumn fx:id="dateColumn"
                                 text="Date d'inscription"
                                 prefWidth="170"/>

                </columns>

                <placeholder>
                    <Label text="Aucun client trouvé."
                           styleClass="page-subtitle"/>
                </placeholder>

            </TableView>

            <!-- ACTIONS -->
            <HBox alignment="CENTER_RIGHT" spacing="12">

                <Button text="Actualiser"
                        onAction="#refreshClients"
                        styleClass="secondary-action-button"/>

                <Button text="Voir les détails"
                        onAction="#handleDetails"
                        styleClass="secondary-action-button"/>

                <Button text="Modifier"
                        onAction="#handleEdit"
                        styleClass="primary-action-button"/>

                <Button text="Supprimer"
                        onAction="#handleDelete"
                        styleClass="logout-button"/>

            </HBox>

            <!-- MESSAGE -->
            <Label fx:id="messageLabel"
                   text=""
                   wrapText="true"/>

        </VBox>
    </center>

</BorderPane>