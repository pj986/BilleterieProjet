<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.ForgotPasswordController"
            prefWidth="900"
            prefHeight="600"
            styleClass="login-page">

    <VBox alignment="CENTER"
          spacing="18"
          AnchorPane.topAnchor="0"
          AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0">
        <Button text="← Retour"
                onAction="#goBack"
                styleClass="back-button"/>

        <Label text="Mot de passe oublié"
               styleClass="app-title"/>

        <Label text="Réinitialisation du mot de passe administrateur"
               styleClass="subtitle"/>

        <TextField fx:id="emailField"
                   promptText="Adresse email du compte"
                   maxWidth="320"/>

        <Button text="Générer un code"
                onAction="#handleGenerateCode"
                styleClass="primary-button"/>

        <Separator maxWidth="320"/>

        <TextField fx:id="codeField"
                   promptText="Code reçu / généré"
                   maxWidth="320"/>

        <PasswordField fx:id="newPasswordField"
                       promptText="Nouveau mot de passe"
                       maxWidth="320"/>

        <PasswordField fx:id="confirmPasswordField"
                       promptText="Confirmer le mot de passe"
                       maxWidth="320"/>

        <Button text="Réinitialiser le mot de passe"
                onAction="#handleResetPassword"
                styleClass="success-button"/>

        <Button text="Retour à la connexion"
                onAction="#goBackToLogin"
                styleClass="secondary-button"/>

        <Label fx:id="messageLabel"
               styleClass="error-label"/>

    </VBox>

</AnchorPane>